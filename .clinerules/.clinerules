# ============================================================================
# .clinerules — Cline Configuration for onitask
# ============================================================================
# Version: 1.2.0
# Date: 2026-07-12
# Purpose: System configuration + Plan Mode guidelines for onitask development

# ============================================================================
# PROJECT CONTEXT
# ============================================================================
project:
  name: onitask
  description: "AI-Native Control Plane for hybrid teams (humans + AI agents)"
  docs_path: docs/                         # ← исправлено: все документы в /docs
  schema_path: supabase/migrations
  version: "0.13.3"
  status: "Active Development"

# ============================================================================
# PLAN MODE GUIDELINES (onitask — Optimized for Cline + Kimi k2.6)
# ============================================================================
plan_mode:
  enabled: true
  description: "Plan Mode guidelines for Cline + Kimi k2.6 in onitask project"
  
  # 1. Deep Context Gathering
  deep_context_gathering:
    allowed_tools:
      - read_file
      - list_files
      - search_files
      - grep
    forbidden_tools:
      - write_to_file
      - replace_in_file
      - execute_command
    required_documents:
      - docs/onitask_Architecture_Master_.md
      - docs/onitask_INDEX_.md
      - docs/onitask_ai_.md
      - docs/onitask_flow_.md
      - docs/onitask_mcp_contract_.md
      - docs/onitask_sql_anomalies_.md
      - docs/onitask_security_.md
      - docs/onitask_bot.md
      - docs/onitask_dev_setup.md
      - docs/onitask_product_vision.md
    cross_document_check: true
    verify_paths_before_planning: true

  # 2. Strict Plan Structure (шаблон)
  strict_plan_structure:
    template: |
      ### 🏗️ Architectural Analysis
      - **Affected Dependencies**: ...
      - **Cross-Document Impact**: ...
      - **Identified Risks**: ...
      - **INV/Axiom Check**: ...

      ### 🗂️ File Mutation Map
      - ➕ **New Files**: ...
      - 📝 **Modified Files**: ...
      - 🚫 **Forbidden Files**: ...
      - ⚠️ **Schema Migration Required?**: ...

      ### ⏱️ Atomic Implementation Steps
      - (используй критический порядок ниже)

      ### ✅ Definition of Done & Validation
      - (используй команды из validation_commands)

    atomic_implementation_steps:
      critical_order_for_schema_changes:
        - "1. Update Master Spec §6 (DDL)"
        - "2. Create/modify SQL migration (supabase/migrations/)"
        - "3. Update feature document (AI/Flow/MCP/SQL Anomalies/Bot/Security)"
        - "4. Update MCP Contract if APIs change"
        - "5. Update Dev Setup if API contracts change"
        - "6. Implement Route Handler / Edge Function"
        - "7. Implement UI components"
      expected_outcome: "Each step must have a clear 'Expected Outcome'."
    
    definition_of_done:
      validation_commands:
        - "supabase db push --dry-run (schema validation)"
        - "supabase functions serve <function-name> (Edge Function test)"
        - "npm run type-check (TypeScript validation)"
        - "curl -X POST /api/mcp/<tool> (MCP contract test)"
      sql_validation: "Run `SELECT * FROM view_name LIMIT 1;` for new views."

  # 3. Specific Safeguards
    context_window: "262K tokens — load ALL relevant onitask documents in Plan Mode"
    anti_overengineering: "Focus only on the requested task. Do not rewrite, refactor, or optimize unrelated code unless explicitly asked."
    verification_first: "Always include automated verification steps in the plan to leverage reasoning capabilities."
    token_monitoring: "Track usage — if approaching free tier limits, recommend switching to paid tier ($0.684/M input, $3.42/M output)."

  # 4. Integration with Existing Tasks
  integration_with_existing_tasks:
    map_task_to_plan: "When a user selects or provides a task from the `tasks` list, map that task directly into this Plan Mode structure."
    mode_transition: "Do not move to ACT MODE until the user explicitly says 'Approved', 'Go', or switches the toggle manually."
    complex_tasks: "For complex tasks, start with `/deep-planning` to create `implementation_plan.md`."

  # 5. onitask-Specific Best Practices
  onitask_specific_best_practices:
    - "**Schema First**: All DDL changes start in Master Spec §6, then migrations."
    - "**INV/Axiom Validation**: Every change must check affected invariants (INV-01…INV-16)."
    - "**Cross-Doc Consistency**: Update all feature documents that reference changed fields."
    - "**Security First**: For AI changes, verify data_sharing_level and allowed_tools."
    - "**Backward Compatibility**: MCP API changes must maintain backward compatibility (versioning or optional fields)."
    - "**SQL Performance**: New views must have EXPLAIN ANALYZE < 50ms on test data."

# ============================================================================
# ARCHITECTURE CONSTRAINTS
# ============================================================================
# Полный список INV и Axiom см. в docs/onitask_Architecture_Master_.md
# Для быстрого доступа приведены ключевые:

invariants:
  - INV-01: tasks.assigned_to → REFERENCES workers(id)
  - INV-02: tasks.reviewer_id → REFERENCES workers(id)
  - INV-03: task_column_history.moved_by → REFERENCES workers(id)
  - INV-04: agent_events триггер auto_create_agent_worker()
  - INV-05: Все AI-outputs содержат workspace_id
  - INV-06: Все секреты сравниваются через timingSafeEqual
  - INV-07: Квота AI инкрементируется через atomic RPC
  - INV-08: workspace_settings — единственный источник настроек
  - INV-09: version на tasks инкрементируется атомарно
  - INV-10: workspace_telegram_chats.linked_by → REFERENCES profiles(id)
  - INV-11: workspaces.task_prefix иммутабелен после создания
  - INV-12: assignment_history.snapshot_attention_risk фиксируется триггером
  - INV-13: task_relations.workspace_id передаётся явно
  - INV-14: workspace_context и workspace_context_cache строго разделены
  - INV-15: data_sharing_level = 'full' только Admin/Owner с DPA
  - INV-16: /api/init — find-or-create только

axioms:
  - A-01: Vercel = только Hot Path (< 2s)
  - A-02: Timing Safe & DB Isolation
  - A-03: Atomic Quota
  - A-04: Векторное индексирование (pgvector)
  - A-05: Гибридный двухконтурный учёт оценок
  - A-06: Один вызов модели (No Fallback Chain)
  - A-07: Tenant Isolation
  - A-08: Flow Access Control
  - A-09: Cognitive Budget Formula
  - A-10: Layered Metrics Cache
  - A-11: Assignment Risk Score
  - A-12: Relational Context Layer

# ============================================================================
# FILE MUTATION GUARDRAILS
# ============================================================================
forbidden_files:
  - supabase/migrations/001_init.sql
  - supabase/migrations/002_rls.sql
  - docs/onitask_Architecture_Master_.md  # Изменяется только через план с INV-check
  - docs/onitask_INDEX_.md

# ============================================================================
# TESTING & VALIDATION
# ============================================================================
validation_commands:
  schema: "supabase db push --dry-run"
  type_check: "npm run type-check"
  lint: "npm run lint"
  edge_function: "supabase functions serve <function-name>"
  mcp_contract: "curl -X POST /api/mcp/<tool>"
  sql_view: "SELECT * FROM view_name LIMIT 1;"

# ============================================================================
# MEMORY BANK CONFIGURATION
# ============================================================================
memory_bank:
  path: docs/memory-bank
  files:
    - projectbrief.md
    - productContext.md
    - activeContext.md
    - systemPatterns.md
    - techContext.md
    - progress.md
  auto_update: true

# ============================================================================
# BEHAVIORAL SAFEGUARDS
# ============================================================================
behavioral_safeguards:
  context_drift_prevention: "Use Focus Chain (automatic todo list) to maintain focus."
  long_conversations: "Use `/smol` or Auto Compact to summarize and reset."
  clean_starts: "At natural transition points (e.g., after research), use `/newtask` to start a clean session."
  planning_files: "Write plans in Markdown (.md) files so they can be referenced later."

# ============================================================================
# Front-End & Figma Code Generation Rules
Ты — senior frontend developer. 
Всегда:
- Используй Auto Layout принципы → Flex/Grid
- Предпочитай существующие компоненты
- Следуй design tokens (colors, spacing, typography)
- Пиши чистый, типизированный код
- Добавляй aria-атрибуты
- Обновляй docs/design/component-map.md при добавлении/изменении компонентов

Запрещено: hardcoded colors/spacing, div soup, inline styles если есть Tailwind.
