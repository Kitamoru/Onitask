{
  "framework": "nextjs",
  "functions": {
    "pages/api/**/*.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_SUPABASE_URL": "@supabase-url-secret",
      "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase-anon-key-secret",
      "NEXT_PUBLIC_WEBAPP_URL": "@webapp-url"
    }
  },
  "env": {
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase-service-role-key-secret",
    "TELEGRAM_BOT_TOKEN": "@telegram-token-secret",
    "MCP_API_KEY": "@mcp-api-key-secret",
    "YANDEX_OAUTH_CLIENT_ID": "@yandex-oauth-client-id-secret",
    "YANDEX_OAUTH_CLIENT_SECRET": "@yandex-oauth-client-secret-secret",
    "OUTLOOK_OAUTH_CLIENT_ID": "@outlook-oauth-client-id-secret",
    "OUTLOOK_OAUTH_CLIENT_SECRET": "@outlook-oauth-client-secret-secret",
    "ENCRYPTION_KEY": "@encryption-key-secret",
    "NEURALDEEP_KEY": "@neuraldeep-key-secret"
  },
  "routes": [
    {
      "src": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://*.supabase.co https://api.telegram.org https://login.yandex.ru https://login.microsoftonline.com; frame-ancestors 'self' https://*.telegram.org;"
        }
      ]
    }
  ]
}
